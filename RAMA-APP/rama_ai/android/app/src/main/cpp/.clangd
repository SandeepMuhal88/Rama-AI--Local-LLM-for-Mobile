CompileFlags:
  Add:
    # ── llama.cpp headers ─────────────────────────────────────────────────────
    - -I./llama.cpp/include
    - -I./llama.cpp
    - -I./llama.cpp/ggml/include
    - -I./llama.cpp/ggml/src

    # ── Android NDK sysroot (fixes 'stdio.h not found', 'stdlib.h', etc.) ────
    # NDK version in use: 28.2.13676358  (from build.gradle.kts)
    # These are the standard C/C++ headers shipped with the NDK toolchain.
    - -isystem
    - C:/Users/sande/AppData/Local/Android/Sdk/ndk/28.2.13676358/toolchains/llvm/prebuilt/windows-x86_64/sysroot/usr/include
    - -isystem
    - C:/Users/sande/AppData/Local/Android/Sdk/ndk/28.2.13676358/toolchains/llvm/prebuilt/windows-x86_64/sysroot/usr/include/aarch64-linux-android
    - -isystem
    - C:/Users/sande/AppData/Local/Android/Sdk/ndk/28.2.13676358/toolchains/llvm/prebuilt/windows-x86_64/lib/clang/18/include

    # ── Android target triple + preprocessor defines ──────────────────────────
    - --target=aarch64-linux-android35
    - -DANDROID
    - -D__ANDROID_API__=35
    - -D__ANDROID__

    # ── Language standard ──────────────────────────────────────────────────────
    - -std=c++17
